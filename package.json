{
  "name": "zample",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n WEB,GATEWAY,LAUNCHES,TASKS -c \"bgBlue.bold,bgMagenta.bold,bgGreen.bold,bgYellow.bold\" \"npm run dev --workspace @zample/web\" \"npm run dev --workspace @zample/api-gateway\" \"npm run dev --workspace @zample/launches-service\" \"npm run dev --workspace @zample/tasks-service\"",
    "dev:web": "npm run dev --workspace @zample/web",
    "dev:gateway": "npm run dev --workspace @zample/api-gateway",
    "dev:launches": "npm run dev --workspace @zample/launches-service",
    "dev:tasks": "npm run dev --workspace @zample/tasks-service",
    "build": "npm run build --workspace @zample/web",
    "prestart": "npm run build --workspace @zample/web",
    "start:web": "npm run start --workspace @zample/web",
    "start:all": "bash ./scripts/start-all.sh",
    "start": "npm run start:all"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
